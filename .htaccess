Options -Indexes

# Page d'erreur personnalisée (Apache)
ErrorDocument 404 /404.html

# Bloquer l'accès HTTP direct aux données, modèles et code serveur (Apache)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^data/ - [F,L]
  RewriteRule ^templates/ - [F,L]
  RewriteRule ^php/ - [F,L]
  RewriteRule ^vendor/ - [F,L]
</IfModule>

# Bloquer l'accès direct à la configuration
<Files "config.php">
  Require all denied
</Files>

# Bloquer l'accès au fichier d'exemple de config (contient la structure)
<Files "config.example.php">
  Require all denied
</Files>
