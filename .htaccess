Options -Indexes

# Bloquer l'accès HTTP direct aux données et modèles (Apache)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^data/ - [F,L]
  RewriteRule ^templates/ - [F,L]
</IfModule>

# Bloquer l'accès direct à la configuration
<Files "config.php">
  Require all denied
</Files>

# Bloquer l'accès au fichier d'exemple de config (contient la structure)
<Files "config.example.php">
  Require all denied
</Files>
